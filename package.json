{
  "name": "fusion-360-mcp",
  "version": "0.1.0",
  "description": "MCP server for Autodesk Fusion 360 - AI-driven parametric CAD/CAM",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fusion-360-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": ["mcp", "fusion-360", "cad", "cam", "autodesk", "ai"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
